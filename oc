    echo "  oc types              TypeScript check + corrige"
    echo "  oc test               Roda testes + corrige falhas"
    echo "  oc search \"<query>\"   Pesquisa profunda no codebase"
    echo "  oc refactor <alvo>    Refatora arquivo/componente"
