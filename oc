#!/bin/bash
# oc - OpenClaw → Claude Code bridge para CYPHER-V3
# Versao 2.0 — Com retry automatico e comandos focados

PROJECT_DIR="$HOME/CYPHER-V3"
CLAUDE_CMD="claude --dangerously-skip-permissions"

# Cores Bloomberg Terminal
GREEN='\033[0;32m'
ORANGE='\033[0;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Retry com backoff ────────────────────────────────────────────────────────
run_claude() {
    local prompt="$1"
    local label="${2:-tarefa}"
    local max_retries=3
    local attempt=1

    echo ""
    echo -e "${ORANGE}┌─ [OpenClaw → Claude Code] ─────────────────────────────┐${NC}"
    echo -e "${ORANGE}│${NC} ${BOLD}$label${NC}"
    echo -e "${ORANGE}└────────────────────────────────────────────────────────┘${NC}"

    while [ $attempt -le $max_retries ]; do
        if [ $attempt -gt 1 ]; then
            local wait=$((attempt * 8))
            echo -e "${CYAN}[retry $attempt/$max_retries — aguardando ${wait}s...]${NC}"
            sleep $wait
        fi

        cd "$PROJECT_DIR" && $CLAUDE_CMD -p "$prompt"
        local exit_code=$?

        if [ $exit_code -eq 0 ]; then
            echo ""
            echo -e "${GREEN}✓ Concluido: $label${NC}"
            return 0
        fi

        echo -e "${RED}✗ Falhou (exit $exit_code) — tentativa $attempt/$max_retries${NC}"
        attempt=$((attempt + 1))
    done

    echo -e "${RED}✗ Falhou apos $max_retries tentativas: $label${NC}"
    return 1
}

run_claude_continue() {
    local prompt="$1"
    local label="${2:-continuacao}"
    echo ""
    echo -e "${ORANGE}┌─ [OpenClaw → Claude Code :: CONTINUAR] ────────────────┐${NC}"
    echo -e "${ORANGE}│${NC} ${BOLD}$label${NC}"
    echo -e "${ORANGE}└────────────────────────────────────────────────────────┘${NC}"
    cd "$PROJECT_DIR" && $CLAUDE_CMD --continue -p "$prompt"
}

