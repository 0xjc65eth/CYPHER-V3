# ===================================================================
# CYPHER ORDi FUTURE V3 - Environment Variables
# ===================================================================
# Copy this file to .env.local and fill in your values.
# ===================================================================

# ---- Core ----
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_SITE_URL=https://cypher-v3.vercel.app
NEXT_PUBLIC_APP_URL=https://cypher-v3.vercel.app
NEXTAUTH_URL=https://cypher-v3.vercel.app
NEXT_PUBLIC_BITCOIN_NETWORK=mainnet
NEXT_PUBLIC_BUILD_VERSION=0.014

# ---- Auth Secrets ----
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your_nextauth_secret_here
JWT_SECRET=your_jwt_secret_here
ADMIN_JWT_SECRET=your_admin_jwt_secret_here
AGENT_ENCRYPTION_KEY=your_agent_encryption_key_here
SECURITY_ENCRYPTION_KEY=your_security_encryption_key_here

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=

# ---- Redis (empty = in-memory fallback) ----
REDIS_URL=

# ---- Market Data APIs (server-side only) ----
CMC_API_KEY=your_coinmarketcap_api_key_here
COINGECKO_API_KEY=
NEXT_PUBLIC_COINGECKO_API=https://api.coingecko.com/api/v3
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_API_URL=https://api.binance.com
GLASSNODE_API_KEY=
CRYPTOCOMPARE_API_KEY=
CRYPTOPANIC_API_KEY=

# ---- Bitcoin & Ordinals (server-side only — use /api/ proxy routes) ----
HIRO_API_KEY=your_hiro_api_key_here
HIRO_API_URL=https://api.hiro.so
NEXT_PUBLIC_HIRO_API_URL=https://api.hiro.so
NEXT_PUBLIC_HIRO_API_TIMEOUT=30000

ORDISCAN_API_KEY=your_ordiscan_api_key_here
ORDISCAN_API_URL=https://api.ordiscan.com

UNISAT_API_KEY=your_unisat_api_key_here
UNISAT_API_URL=https://open-api.unisat.io

MAGIC_EDEN_API_KEY=your_magic_eden_api_key_here
MAGIC_EDEN_API_URL=https://api-mainnet.magiceden.dev

BESTINSLOT_API_KEY=
MEMPOOL_API_URL=https://mempool.space/api
NEXT_PUBLIC_MEMPOOL_API=https://mempool.space/api
BLOCKCYPHER_API_KEY=
BLOCKCYPHER_API_URL=https://api.blockcypher.com/v1/btc/main

# ---- OKX ----
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_API_URL=https://www.okx.com
OKX_WEB3_API_KEY=
OKX_WEB3_SECRET_KEY=
OKX_WEB3_PASSPHRASE=
OKX_WEB3_PROJECT_ID=
OKX_WEB3_API_URL=https://web3.okx.com

# ---- DEX Trading ----
HYPERLIQUID_API_KEY=your_hyperliquid_api_key_here
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_TESTNET=false
HYPERLIQUID_AGENT_KEY=
HYPERLIQUID_AGENT_SECRET=
ONEINCH_API_KEY=
ONE_INCH_API_KEY=
PARASWAP_API_KEY=

# ---- RPC Endpoints (free public) ----
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ETH_RPC_URL=https://eth.llamarpc.com
ETH_CHAIN_ID=1
NEXT_PUBLIC_ETH_RPC_URL=https://eth.llamarpc.com
NEXT_PUBLIC_ARB_RPC_URL=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_OP_RPC_URL=https://mainnet.optimism.io
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc
NEXT_PUBLIC_BSC_RPC_URL=https://bsc-dataseed.binance.org
QUICKNODE_URL=
QUICKNODE_API_KEY=
ALCHEMY_API_KEY=
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
BLOCKNATIVE_API_KEY=

# ---- AI & LLM ----
OPENAI_API_KEY=
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
GROK_API_KEY=your_grok_api_key_here
GROK_API_URL=https://api.x.ai/v1
GROK_MODEL=grok-4-latest
XAI_API_KEY=your_xai_api_key_here
XAI_API_URL=https://api.x.ai/v1/chat/completions
CONSENSUS_LLM_MODEL=grok-3-mini
CONSENSUS_MIN_CONFIDENCE=0.65
NEURAL_API_KEY=

# ---- Text-to-Speech (server-side only) ----
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_API_URL=https://api.elevenlabs.io

# ---- Analytics ----
DUNE_API_KEY=your_dune_api_key_here
TWELVEDATA_API_KEY=your_twelvedata_api_key_here
FRED_API_KEY=
NEWSAPI_KEY=your_newsapi_key_here
RAPIDAPI_KEY=

# ---- Social (all optional) ----
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_API_KEY=
TELEGRAM_API_KEY=
BLOOMBERG_API_KEY=

# ---- Wallet ----
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_MAESTRO_API_KEY_MAINNET=
NEXT_PUBLIC_MAESTRO_API_KEY_TESTNET4=
XVERSE_API_KEY=

# ---- OAuth ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_API_KEY=
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Fee Wallets ----
CYPHER_FEE_EVM=your_evm_fee_wallet_address
CYPHER_FEE_SOLANA=your_solana_fee_wallet_address
CYPHER_FEE_BITCOIN=your_bitcoin_fee_wallet_address
CYPHER_SWAP_FEE_BPS=30
FEE_RECIPIENT_ADDRESS=your_fee_recipient_address
NEXT_PUBLIC_FEE_COLLECTOR_ETH=your_eth_fee_collector_address
NEXT_PUBLIC_FEE_COLLECTOR_ARB=your_arb_fee_collector_address
NEXT_PUBLIC_FEE_COLLECTOR_OP=your_op_fee_collector_address
NEXT_PUBLIC_FEE_COLLECTOR_POLYGON=your_polygon_fee_collector_address
NEXT_PUBLIC_FEE_COLLECTOR_BASE=your_base_fee_collector_address
NEXT_PUBLIC_FEE_COLLECTOR_AVAX=your_avax_fee_collector_address
NEXT_PUBLIC_FEE_COLLECTOR_BSC=your_bsc_fee_collector_address

# ---- Referrals ----
THORCHAIN_AFFILIATE_CODE=cy
THORCHAIN_AFFILIATE_ADDRESS=your_thorchain_affiliate_address
HYPERLIQUID_REFERRAL_CODE=CYPHER
GMX_REFERRAL_CODE=cypher
KWENTA_REFERRAL_CODE=cypher
JUPITER_REFERRAL_ACCOUNT=

# ---- Feature Flags ----
NEXT_PUBLIC_ENABLE_TRADING=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_TESTNET=false
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_ENABLE_DEV_TOOLS=false
NEXT_PUBLIC_CACHE_ENABLED=true

# ---- System ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=info
NODE_OPTIONS=--max-old-space-size=4096
ENABLE_DETAILED_LOGS=false
ENABLE_API_MOCKING=false
PORT=4444
WS_PORT=8080
METRICS_PORT=9090
NEXT_PUBLIC_WS_URL=

# ---- Private Keys (empty = disabled) ----
SOLANA_PRIVATE_KEY=
ETH_PRIVATE_KEY=

# ---- Email (optional) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true

# ---- Monitoring (Docker only) ----
GRAFANA_URL=
GRAFANA_API_KEY=
GRAFANA_ORG_ID=
PROMETHEUS_URL=
INFLUXDB_URL=
ELASTICSEARCH_URL=

# ---- BTCPay (Bitcoin + Lightning) ----
BTCPAY_HOST=
BTCPAY_STORE_ID=
BTCPAY_API_KEY=
BTCPAY_WEBHOOK_SECRET=

# ---- Misc ----
NEXT_PUBLIC_API_BASE_URL=
QUICKTRADE_API_KEY=
WHITELISTED_IPS=
ADMIN_PASSWORD_HASH=
