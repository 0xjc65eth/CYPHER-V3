# ===================================================================
# CYPHER ORDi FUTURE V3 - Environment Variables Template
# ===================================================================
# Copy this file to .env.local and fill in your API keys
# ===================================================================

# ===================================================================
# COINMARKETCAP API (REQUIRED - Main price data)
# ===================================================================
# Get your API key from: https://pro.coinmarketcap.com/api/
CMC_API_KEY=your_cmc_api_key_here

# ===================================================================
# HIRO.SO API (Bitcoin Ordinals & Runes)
# ===================================================================
# Get your API key from: https://docs.hiro.so/get-started/authentication
HIRO_API_KEY=your_hiro_api_key_here
HIRO_API_URL=https://api.hiro.so

# ===================================================================
# ELEVENLABS API (Text-to-Speech AI)
# ===================================================================
# Get your API key from: https://elevenlabs.io/api
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_API_URL=https://api.elevenlabs.io

# ===================================================================
# HYPERLIQUID API (DEX Trading)
# ===================================================================
# Get your API key from: https://app.hyperliquid.xyz/
HYPERLIQUID_API_KEY=your_hyperliquid_api_key_here
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

# ===================================================================
# ORDISCAN API (Bitcoin Ordinals Data)
# ===================================================================
# Get your API key from: https://ordiscan.com/api
ORDISCAN_API_KEY=your_ordiscan_api_key_here
ORDISCAN_API_URL=https://api.ordiscan.com

# ===================================================================
# ADDITIONAL CRYPTO APIS
# ===================================================================

# Mempool.space API (Bitcoin Network Data - Free)
MEMPOOL_API_URL=https://mempool.space/api

# BlockCypher API (Bitcoin Blockchain Data)
BLOCKCYPHER_API_KEY=your_blockcypher_api_key_here
BLOCKCYPHER_API_URL=https://api.blockcypher.com/v1/btc/main

# UniSat API (Bitcoin Ordinals & BRC-20)
UNISAT_API_KEY=your_unisat_api_key_here
UNISAT_API_URL=https://open-api.unisat.io

# Magic Eden API (NFT & Ordinals Marketplace)
MAGIC_EDEN_API_KEY=your_magic_eden_api_key_here
MAGIC_EDEN_API_URL=https://api-mainnet.magiceden.dev

# OKX API (Ordinals Trading - Legacy)
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here
OKX_API_URL=https://www.okx.com

# OKX Web3 API (DEX Aggregator, Market Data, Balance, x402)
# Get credentials from: https://web3.okx.com/build/dev-docs
OKX_WEB3_API_KEY=your_okx_web3_api_key_here
OKX_WEB3_SECRET_KEY=your_okx_web3_secret_key_here
OKX_WEB3_PASSPHRASE=your_okx_web3_passphrase_here
OKX_WEB3_PROJECT_ID=your_okx_web3_project_id_here
OKX_WEB3_API_URL=https://web3.okx.com

# Binance API (Price data)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_API_URL=https://api.binance.com

# ===================================================================
# AI & ANALYSIS APIS
# ===================================================================

# OpenAI API (GPT Analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (AI Analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===================================================================
# DATABASE & STORAGE (REQUIRED for production persistence)
# ===================================================================
# Without these, data is stored in-memory and lost on restart.
# See database/migrations/001_initial_schema.sql for schema setup.

# Supabase (Database & Auth) - REQUIRED for persistent storage
# Tables: users, fee_records, admin_sessions, admin_users,
#          transaction_history, trading_signals, user_settings,
#          neural_models, market_data, neural_insights, job_records
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Redis (Caching & Sessions) - RECOMMENDED for production
# Used for: session caching, rate limiting, job locking, price cache
# Falls back to in-memory if not set
REDIS_URL=redis://localhost:6379

# ===================================================================
# WALLET & AUTHENTICATION
# ===================================================================

# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://your-deployed-app-url.com

# Bitcoin Wallet Authentication (REQUIRED for Bitcoin auth system)
# Used by /lib/auth/bitcoin-auth.ts for signing JWT tokens
# Generate a secure random string (minimum 32 characters)
# Example: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_min_32_chars_change_in_production_please

# GitHub OAuth (for auth)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ===================================================================
# DEPLOYMENT & ENVIRONMENT
# ===================================================================

# Environment
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# App Configuration
NEXT_PUBLIC_APP_URL=https://your-deployed-app-url.com
NEXT_PUBLIC_BITCOIN_NETWORK=mainnet

# Feature Flags
NEXT_PUBLIC_ENABLE_TRADING=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_TESTNET=false

# ===================================================================
# ADMIN AUTHENTICATION
# ===================================================================

# Admin JWT secret (REQUIRED for admin panel)
ADMIN_JWT_SECRET=your_admin_jwt_secret_here

# Admin password hash (SHA-256, for fallback auth without DB)
# ADMIN_PASSWORD_HASH=sha256_hash_of_admin_password

# ===================================================================
# SYSTEM CONFIGURATION
# ===================================================================

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Ports
WS_PORT=8080
METRICS_PORT=9090

# Logging
LOG_LEVEL=info

# Performance
NODE_OPTIONS=--max-old-space-size=8192

# ===================================================================
# AI TRADING AGENT (Autonomous, No KYC)
# ===================================================================

# Grok (xAI) API - Used for LLM consensus agent
# Get your API key from: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here
XAI_API_URL=https://api.x.ai/v1/chat/completions
CONSENSUS_LLM_MODEL=grok-3-mini
CONSENSUS_MIN_CONFIDENCE=0.65

# Hyperliquid Agent Wallet (for autonomous perp trading)
HYPERLIQUID_AGENT_KEY=your_agent_wallet_key_here
HYPERLIQUID_AGENT_SECRET=your_agent_wallet_secret_here
HYPERLIQUID_TESTNET=true

# Solana RPC (for Jupiter/Raydium LP)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# EVM RPC (for Uniswap LP)
ETH_RPC_URL=https://eth.llamarpc.com
ETH_CHAIN_ID=1

# Agent Session Key Encryption (32-byte hex)
# Generate: openssl rand -hex 32
AGENT_ENCRYPTION_KEY=your_32_byte_hex_here

# ===================================================================
# MULTI-ASSET MARKET DATA (Bloomberg Terminal)
# ===================================================================

# Twelve Data API (Forex, Stocks, Commodities, Indices)
# Get your API key from: https://twelvedata.com/apikey
# Free tier: 8 req/min, 800 req/day
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# FRED API (Federal Reserve Economic Data)
# Get your API key from: https://fred.stlouisfed.org/docs/api/api_key.html
# Free: 120 req/min
FRED_API_KEY=your_fred_api_key_here

# NewsAPI (Financial News Headlines)
# Get your API key from: https://newsapi.org/register
# Free tier: 100 req/day
NEWSAPI_KEY=your_newsapi_key_here

# ===================================================================
# DEVELOPMENT ONLY
# ===================================================================

# Development flags (set to false in production)
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_ENABLE_DEV_TOOLS=false