# Production Environment Variables for Netlify
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NODE_OPTIONS=--max-old-space-size=8192

# API Keys (server-side only - no NEXT_PUBLIC_ prefix for secrets)
CMC_API_KEY=your_key_here
HYPERLIQUID_API_KEY=your_key_here
ELEVENLABS_API_KEY=your_key_here
ORDISCAN_API_KEY=your_key_here
HIRO_API_KEY=your_key_here
QUICKNODE_API_KEY=your_key_here

# Public keys (safe to expose in browser)
NEXT_PUBLIC_HIRO_API_KEY=your_key_here
NEXT_PUBLIC_ORDISCAN_API_KEY=your_key_here
NEXT_PUBLIC_COINMARKETCAP_API_KEY=your_key_here

# Security
ADMIN_JWT_SECRET=your_secure_jwt_secret_minimum_32_chars
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://your-domain.netlify.app

# Domain Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.netlify.app

# VIP Wallets (comma-separated)
VIP_WALLETS_FULL_ACCESS=
VIP_WALLET_SUPER_ADMIN=
